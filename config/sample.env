# Обязательно для Tracker API
YATRACKER_TOKEN=your_oauth_token_here
YATRACKER_ORG_ID=your_organization_id

# Необязательно: Client ID OAuth-приложения (https://oauth.yandex.ru/) — для ручного
# получения или смены токена. Само API Трекера использует только YATRACKER_TOKEN.
# YATRACKER_OAUTH_CLIENT_ID=your_client_id

# Дополнительно
# YATRACKER_CLOUD_ORG_ID=your_cloud_org_id
# YATRACKER_API_URL=https://api.tracker.yandex.net/v3
